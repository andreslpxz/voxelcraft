<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Sombra inferior sutil -->
    <item android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#33000000" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- Cuerpo principal con gradiente verde (primary) -->
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@color/vc_primary_light"
                android:centerColor="@color/vc_primary"
                android:endColor="@color/vc_primary_dark" />
            <stroke android:width="2dp" android:color="#40FFFFFF" />
            <padding
                android:left="0dp"
                android:top="0dp"
                android:right="0dp"
                android:bottom="0dp" />
        </shape>
    </item>
    <!-- Brillo superior -->
    <item android:bottom="4dp" android:top="2dp" android:start="2dp" android:end="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#66FFFFFF"
                android:endColor="#00FFFFFF" />
            <size android:height="20dp" />
        </shape>
    </item>
</layer-list>
