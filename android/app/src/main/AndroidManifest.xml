<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:name="android.hardware.touchscreen" android:required="true"/>
    <uses-feature android:name="android.hardware.vulkan.version" android:required="true" android:version="0x00401000"/>
    <uses-feature android:name="android.hardware.vulkan.level" android:required="true" android:version="0x00401000"/>

    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.VoxelCraft"
        android:hardwareAccelerated="true">

        <!-- =================================================== -->
        <!-- Pantalla de menú principal — es el LAUNCHER.        -->
        <!-- =================================================== -->
        <activity
            android:name=".MenuActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden|navigation"
            android:theme="@style/Theme.VoxelCraft.Menu">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- =================================================== -->
        <!-- Actividad del juego (Vulkan NativeActivity).         -->
        <!-- Lanzada por MenuActivity al pulsar JUGAR.             -->
        <!-- =================================================== -->
        <activity
            android:name=".GameActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden|navigation"
            android:theme="@style/Theme.VoxelCraft.Game">
            <meta-data
                android:name="android.app.lib_name"
                android:value="voxelcraft"/>
        </activity>

        <!-- Actividad nativa legacy (compatibilidad hacia atrás) -->
        <activity
            android:name="android.app.NativeActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden|navigation"
            android:theme="@style/Theme.VoxelCraft.Game">
            <meta-data
                android:name="android.app.lib_name"
                android:value="voxelcraft"/>
        </activity>
    </application>
</manifest>
