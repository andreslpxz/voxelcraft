<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_menu_gradient"
    android:fitsSystemWindows="false">

    <!-- ============================== -->
    <!-- Capa decorativa: cubos flotantes animados -->
    <!-- ============================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:weightSum="3">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <View
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="40dp"
                android:layout_marginTop="20dp"
                android:alpha="0.55"
                android:background="@drawable/ic_block_grass"
                android:rotation="-12" />

            <View
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="80dp"
                android:layout_marginTop="60dp"
                android:alpha="0.5"
                android:background="@drawable/ic_block_grass"
                android:rotation="18" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <View
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="end|top"
                android:layout_marginEnd="50dp"
                android:layout_marginTop="10dp"
                android:alpha="0.45"
                android:background="@drawable/ic_block_grass"
                android:rotation="8" />

            <View
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="start|bottom"
                android:layout_marginStart="100dp"
                android:layout_marginBottom="10dp"
                android:alpha="0.55"
                android:background="@drawable/ic_block_grass"
                android:rotation="-22" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- ============================== -->
    <!-- Capa principal: logo + botones -->
    <!-- ============================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:paddingTop="40dp"
        android:paddingBottom="24dp">

        <!-- Spacer superior -->
        <View
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_weight="0.8" />

        <!-- Logo principal -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Prefijo cubo decorativo + título -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_block_grass"
                    android:contentDescription="@null"
                    android:elevation="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textAppearance="@style/TextAppearance.VC.Display"
                    android:fontFamily="sans-serif-condensed"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <!-- Tagline debajo del logo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/menu_tagline"
                android:textAppearance="@style/TextAppearance.VC.Body"
                android:fontFamily="sans-serif-light"
                android:alpha="0.9" />

            <!-- Separador decorativo -->
            <View
                android:layout_width="120dp"
                android:layout_height="3dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/ic_block_grass"
                android:alpha="0.7" />
        </LinearLayout>

        <!-- Spacer medio -->
        <View
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- ============================== -->
        <!-- Bloque de botones -->
        <!-- ============================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Botón principal: JUGAR -->
            <Button
                android:id="@+id/btn_play"
                style="@style/Widget.VC.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/menu_play" />

            <!-- Botón secundario: CONTINUAR (carga último save) -->
            <Button
                android:id="@+id/btn_continue"
                style="@style/Widget.VC.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/menu_continue" />

            <!-- Fila de botones terciarios -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/btn_settings"
                    style="@style/Widget.VC.Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="7dp"
                    android:text="@string/menu_settings" />

                <Button
                    android:id="@+id/btn_about"
                    style="@style/Widget.VC.Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="7dp"
                    android:text="@string/menu_about" />
            </LinearLayout>

            <!-- Botón salir -->
            <Button
                android:id="@+id/btn_quit"
                style="@style/Widget.VC.Button.Secondary"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/menu_quit" />
        </LinearLayout>

        <!-- Spacer inferior -->
        <View
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_weight="0.4" />

    </LinearLayout>

    <!-- ============================== -->
    <!-- Footer: versión + crédito -->
    <!-- ============================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="14dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/about_author"
            android:textColor="@color/vc_text_secondary"
            android:textSize="12sp"
            android:fontFamily="sans-serif-light" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/menu_version"
            android:textColor="@color/vc_text_secondary"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:alpha="0.8" />
    </LinearLayout>

</FrameLayout>
