<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#FF3DDC84"
                android:endColor="#FF1FAE6B" />
            <stroke android:width="3dp" android:color="#FFFFFFFF" />
            <padding
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp" />
        </shape>
    </item>
    <item android:left="6dp" android:top="6dp" android:right="6dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <solid android:color="#FF3E6B2F" />
        </shape>
    </item>
</layer-list>
