    <color name="vc_primary_light">#FF6FEFAE</color>
    <color name="vc_sky_bottom">#FFB5E0FF</color>
    <color name="vc_sky_mid">#FF6FB1F0</color>
    <color name="vc_sky_top">#FF4A90E2</color>
    <color name="vc_stone">#FF8A8A8A</color>
    <color name="vc_text_dark">#FF1A1A1A</color>
    <color name="vc_text_dim">#FF6B6B6B</color>
    <color name="vc_text_primary">#FFFFFFFF</color>
    <color name="vc_text_secondary">#B3FFFFFF</color>
    <string name="about_author">Desarrollado por @andreslpxz</string>
    <string name="about_body">VoxelCraft es un sandbox de bloques open-source para Android, renderizado nativamente con Vulkan. Construye, explora y sobrevive en un mundo procedural infinito.</string>
    <string name="about_engine">Motor: Vulkan 1.1 · C++17 · Kotlin</string>
    <string name="about_title">Acerca de VoxelCraft</string>
    <string name="app_name">VoxelCraft</string>
    <string name="common_back">VOLVER</string>
    <string name="common_close">CERRAR</string>
    <string name="menu_about">ACERCA DE</string>
    <string name="menu_continue">CONTINUAR</string>
    <string name="menu_new_world">NUEVO MUNDO</string>
    <string name="menu_play">JUGAR</string>
    <string name="menu_quit">SALIR</string>
    <string name="menu_settings">CONFIGURACIÓN</string>
    <string name="menu_tagline">Un sandbox de bloques infinito</string>
    <string name="menu_version">v1.0.0</string>
    <string name="settings_graphics">Calidad gráfica</string>
    <string name="settings_render_distance">Distancia de renderizado</string>
    <string name="settings_render_distance_value">%d chunks</string>
    <string name="settings_sensitivity">Sensibilidad</string>
    <string name="settings_title">Configuración</string>
    <style name="TextAppearance.VC.Body" parent="@android:style/TextAppearance">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/vc_text_secondary</item>
    </style>
    <style name="TextAppearance.VC.Button" parent="@android:style/TextAppearance">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textColor">@color/vc_text_primary</item>
        <item name="android:textAllCaps">true</item>
    </style>
    <style name="TextAppearance.VC.Display" parent="@android:style/TextAppearance">
        <item name="android:textSize">64sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textColor">@color/vc_text_primary</item>
        <item name="android:shadowColor">#80000000</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">6</item>
        <item name="android:shadowRadius">12</item>
    </style>
    <style name="TextAppearance.VC.Title" parent="@android:style/TextAppearance">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/vc_text_primary</item>
    </style>
    <style name="Theme.VoxelCraft" parent="@android:style/Theme.DeviceDefault.NoActionBar.Fullscreen">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@color/vc_sky_top</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
    <style name="Theme.VoxelCraft.Game" parent="@android:style/Theme.DeviceDefault.NoActionBar.Fullscreen">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>
    <style name="Theme.VoxelCraft.Menu" parent="@android:style/Theme.DeviceDefault.NoActionBar.Fullscreen">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@drawable/bg_menu_gradient</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
    </style>
    <style name="Widget.VC.Button.Primary" parent="@android:style/Widget.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textAppearance">@style/TextAppearance.VC.Button</item>
        <item name="android:textColor">@color/vc_text_primary</item>
        <item name="android:paddingTop">18dp</item>
        <item name="android:paddingBottom">18dp</item>
        <item name="android:paddingStart">40dp</item>
        <item name="android:paddingEnd">40dp</item>
        <item name="android:minHeight">64dp</item>
        <item name="android:elevation">8dp</item>
        <item name="android:stateListAnimator">@animator/button_raise</item>
    </style>
    <style name="Widget.VC.Button.Secondary" parent="@android:style/Widget.Button">
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:textAppearance">@style/TextAppearance.VC.Button</item>
        <item name="android:textColor">@color/vc_text_primary</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:paddingStart">32dp</item>
        <item name="android:paddingEnd">32dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:elevation">4dp</item>
        <item name="android:stateListAnimator">@animator/button_raise</item>
    </style>
</resources>