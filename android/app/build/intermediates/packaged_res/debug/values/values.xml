    <color name="vc_button_shadow">#66000000</color>
    <color name="vc_card_bg">#F2FFFFFF</color>
    <color name="vc_danger">#FFEF5350</color>
    <color name="vc_dirt">#FF7B5A3A</color>
    <color name="vc_grass">#FF5B9A48</color>
    <color name="vc_grass_dark">#FF3E6B2F</color>
    <color name="vc_grass_light">#FF7FC26B</color>
    <color name="vc_logo_bottom">#FF4A90E2</color>
    <color name="vc_logo_top">#FF8B6FE0</color>
    <color name="vc_primary">#FF3DDC84</color>
