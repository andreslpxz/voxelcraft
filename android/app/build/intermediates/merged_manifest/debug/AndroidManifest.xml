<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.voxelcraft"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="28"
        android:targetSdkVersion="34" />

    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.vulkan.version"
        android:required="true"
        android:version="0x00401000" />
    <uses-feature
        android:name="android.hardware.vulkan.level"
        android:required="true"
        android:version="0x00401000" />

    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <permission
        android:name="com.voxelcraft.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.voxelcraft.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.VoxelCraft" >

        <!-- =================================================== -->
        <!-- Pantalla de menú principal — es el LAUNCHER. -->
        <!-- =================================================== -->
        <activity
            android:name="com.voxelcraft.MenuActivity"
            android:configChanges="orientation|screenSize|keyboardHidden|navigation"
            android:exported="true"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.VoxelCraft.Menu" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- =================================================== -->
        <!-- Actividad del juego (Vulkan NativeActivity). -->
        <!-- Lanzada por MenuActivity al pulsar JUGAR. -->
        <!-- =================================================== -->
        <activity
            android:name="com.voxelcraft.GameActivity"
            android:configChanges="orientation|screenSize|keyboardHidden|navigation"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.VoxelCraft.Game" >
            <meta-data
                android:name="android.app.lib_name"
                android:value="voxelcraft" />
        </activity>

        <!-- Actividad nativa legacy (compatibilidad hacia atrás) -->
        <activity
            android:name="android.app.NativeActivity"
            android:configChanges="orientation|screenSize|keyboardHidden|navigation"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.VoxelCraft.Game" >
            <meta-data
                android:name="android.app.lib_name"
                android:value="voxelcraft" />
        </activity>

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.voxelcraft.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
        </provider>
    </application>

</manifest>